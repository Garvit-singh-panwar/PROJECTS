# Normalize all text files to LF in the repo
* text=auto eol=lf

# Explicit LF for source/config files
*.json   text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.xml    text eol=lf
*.cs     text eol=lf
*.csproj text eol=lf
*.sln    text eol=lf

# Windows batch scripts should stay CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files (no line ending conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.exe  binary
